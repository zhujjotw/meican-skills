# Meican Auto Ordering Skill — Environment Variables
# Copy this file to .env and fill in your values.

# Required: 美餐登录账号（手机号或邮箱）
MEICAN_USERNAME=

# Required: 美餐登录密码
MEICAN_PASSWORD=

# Optional: 登录后缓存的 Token，脚本会自动写入
MEICAN_TOKEN=

# Optional: Cookie 文件路径（默认 /tmp/meican_cookie.txt）
MEICAN_COOKIE_FILE=/tmp/meican_cookie.txt

# Optional: 用于 GitHub 相关操作（如自动更新 skill）
GITHUB_TOKEN=
